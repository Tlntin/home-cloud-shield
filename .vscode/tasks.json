{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "栖云盾: 构建 entry HAP",
      "type": "shell",
      "command": "C:\\Program Files\\HuaWei\\DevEco Studio\\tools\\node\\node.exe",
      "args": [
        "C:\\Program Files\\HuaWei\\DevEco Studio\\tools\\hvigor\\bin\\hvigorw.js",
        "--mode",
        "module",
        "-p",
        "module=entry@default",
        "-p",
        "product=default",
        "-p",
        "requiredDeviceType=phone",
        "assembleHap",
        "--analyze=normal",
        "--parallel",
        "--incremental",
        "--daemon"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "栖云盾: 安装并启动到设备(自动识别)",
      "type": "shell",
      "command": "powershell.exe",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\.vscode\\scripts\\install-and-launch.ps1",
        "-WorkspaceRoot",
        "${workspaceFolder}"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "栖云盾: 构建 + 安装并启动",
      "dependsOrder": "sequence",
      "dependsOn": [
        "栖云盾: 构建 entry HAP",
        "栖云盾: 安装并启动到设备(自动识别)"
      ],
      "problemMatcher": []
    }
  ]
}
